# NATS broker (already deployed in the cluster, core namespace)
NATS_URL=nats://nats.core.svc.cluster.local:4222
NATS_USER=your_nats_user
NATS_PASSWORD=your_nats_password

# LINE Messaging API (same channel as line-webhook)
LINE_CHANNEL_SECRET=your_channel_secret_here
LINE_CHANNEL_ACCESS_TOKEN=your_channel_access_token_here

# Server port for /health (default: 8080)
PORT=8080
