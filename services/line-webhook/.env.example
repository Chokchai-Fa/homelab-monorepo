# LINE Bot Configuration
# Get these values from LINE Developers Console (https://developers.line.biz/)

# Channel Secret from your LINE Bot channel
LINE_CHANNEL_SECRET=your_channel_secret_here

# NATS broker for publishing chat events (replies are sent by
# consumer-reply-line-user; without NATS incoming messages are dropped)
NATS_URL=nats://nats.core.svc.cluster.local:4222
NATS_USER=your_nats_user
NATS_PASSWORD=your_nats_password

# Prefix that routes a message to the AI assistant (default: /ai)
AI_PREFIX=/ai

# Server port (default: 8080)
PORT=8080