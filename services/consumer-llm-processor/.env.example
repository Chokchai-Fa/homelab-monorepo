# NATS broker (already deployed in the cluster, core namespace)
NATS_URL=nats://nats.core.svc.cluster.local:4222
NATS_USER=your_nats_user
NATS_PASSWORD=your_nats_password

# Gemini API (https://aistudio.google.com)
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-3.5-flash

# Postgres for conversation history (source of truth)
DATABASE_URL=postgres://user:password@postgres.core.svc.cluster.local:5432/dbname?sslmode=disable

# Redis shared conversation cache (checked before Postgres)
REDIS_ADDR=redis.core.svc.cluster.local:6379
REDIS_USERNAME=your_redis_user
REDIS_PASSWORD=your_redis_password

# Server port for /health (default: 8080)
PORT=8080
